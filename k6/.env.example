# KitchenPace k6 Load Test Configuration

# Target URL for load testing
BASE_URL=http://localhost:3000

# Alternative URLs:
# BASE_URL=https://kitchenpace.app
# BASE_URL=https://staging.kitchenpace.app

# Test configuration
K6_VUS=100
K6_DURATION=5m

# Output configuration
K6_OUT=json
K6_RESULTS_DIR=./results

# InfluxDB configuration (optional, for real-time monitoring)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_DB=k6

# Threshold configuration
THRESHOLD_HTTP_REQ_DURATION=p(95)<5000
THRESHOLD_ERROR_RATE=rate<0.1
