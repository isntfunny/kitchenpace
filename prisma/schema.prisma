generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

// Roles are stored as strings: "user", "admin", "moderator", "banned"

enum TrophyTier {
  NONE
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum RecipeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum MealStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum NotificationType {
  NEW_FOLLOWER
  RECIPE_LIKE
  RECIPE_COMMENT
  RECIPE_RATING
  RECIPE_COOKED
  RECIPE_PUBLISHED
  WEEKLY_PLAN_REMINDER
  SYSTEM
}

enum ActivityType {
  RECIPE_CREATED
  RECIPE_COOKED
  RECIPE_RATED
  RECIPE_COMMENTED
  RECIPE_FAVORITED
  RECIPE_UNFAVORITED
  USER_FOLLOWED
  USER_REGISTERED
  USER_ACTIVATED
  MEAL_PLAN_CREATED
  SHOPPING_LIST_CREATED
  STREAM_STARTED
}

enum PaletteColor {
  orange
  gold
  emerald
  purple
  blue
  pink
}

enum ModerationStatus {
  APPROVED
  PENDING
  REJECTED
  AUTO_APPROVED
}

// ============================================
// AUTH MODELS (Better Auth)
// ============================================

model Account {
  id                    String     @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([providerId, accountId])
}

model Session {
  id             String    @id @default(cuid())
  token          String    @unique
  userId         String
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Passkey {
  id           String    @id @default(cuid())
  name         String?
  publicKey    String
  userId       String
  credentialID String    @unique
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  aaguid       String?
  createdAt    DateTime  @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// USER & PROFILE
// ============================================

model User {
  id                        String                    @id @default(cuid())
  name                      String?
  email                     String                    @unique
  emailVerified             Boolean                   @default(false)
  image                     String?
  role                      String                    @default("user")
  banned                    Boolean                   @default(false)
  banReason                 String?
  banExpires                DateTime?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  //                        Relations
  accounts                  Account[]
  sessions                  Session[]
  passkeys                  Passkey[]
  profile                   Profile?
  recipes                   Recipe[]
  comments                  Comment[]
  ratings                   UserRating[]
  favorites                 Favorite[]
  followedBy                Follow[]                 @relation("FollowedBy")
  following                 Follow[]                 @relation("Following")
  notifications             Notification[]
  pushSubscriptions         PushSubscription[]
  mealPlans                 MealPlan[]
  shoppingLists             ShoppingList[]
  activities                ActivityLog[]
  viewHistory               UserViewHistory[]
  cookHistory               UserCookHistory[]
  pinnedFavorites           PinnedFavorite[]
  cookImages                CookImage[]
  importRuns                ImportRun[]
  moderationQueueAsAuthor   ModerationQueue[]        @relation("ModerationQueueAuthor")
  moderationQueueAsReviewer ModerationQueue[]        @relation("ModerationQueueReviewer")
  moderationLogs            ModerationLog[]          @relation("ModerationLogActor")
  reports                   Report[]                 @relation("ReportSubmitter")
  tutorialCompletions       UserTutorialCompletion[]
  earnedTrophies            UserTrophy[]
  trophyPoints              Int                       @default(0)
  twitchStream              TwitchStream?
  plannedStreams             PlannedStream[]
}

model UserTutorialCompletion {
  id          String    @id @default(cuid())
  userId      String
  tutorialKey String
  completedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tutorialKey])
  @@index([tutorialKey])
}

model Profile {
  id                         String    @id @default(cuid())
  userId                     String    @unique
  nickname                   String    @db.VarChar(40)
  slug                       String    @unique @db.VarChar(60)
  teaser                     String?
  photoKey                   String?
  bio                        String?
  followerCount              Int       @default(0)
  followingCount             Int       @default(0)
  recipeCount                Int       @default(0)
  ratingsPublic              Boolean   @default(true)
  followsPublic              Boolean   @default(true)
  favoritesPublic            Boolean   @default(true)
  cookedPublic               Boolean   @default(true)
  trophiesPublic             Boolean   @default(true)
  showTrophyOnAvatar         Boolean   @default(true)
  showInActivity             Boolean   @default(true)
  notifyOnAnonymous          Boolean   @default(false)
  notifyOnNewFollower        Boolean   @default(true)
  notifyOnRecipeLike         Boolean   @default(true)
  notifyOnRecipeComment      Boolean   @default(true)
  notifyOnRecipeRating       Boolean   @default(true)
  notifyOnRecipeCooked       Boolean   @default(true)
  notifyOnRecipePublished    Boolean   @default(true)
  notifyOnWeeklyPlanReminder Boolean   @default(true)
  notifyOnSystemMessages     Boolean   @default(true)
  notifyOnNewsletter         Boolean   @default(true)
  notifyOnStreamStarted      Boolean   @default(true)

  // Twitch integration (twitchId lives in account.accountId where providerId='twitch')
  twitchUsername              String?   @db.VarChar(60)
  twitchConnectedAt          DateTime?

  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([nickname])
}

// ============================================
// RECIPE & INGREDIENTS
// ============================================

model Recipe {
  id                                                                         String              @id @default(cuid())
  title                                                                      String
  slug                                                                       String              @unique
  description                                                                String?
  imageKey                                                                   String?
  blurhash                                                                   String?
  imageWidth                                                                 Int?
  imageHeight                                                                Int?
  servings                                                                   Int                 @default(4)
  prepTime                                                                   Int                 @default(0)
  cookTime                                                                   Int                 @default(0)
  totalTime                                                                  Int                 @default(0)
  // Nutrition (auto-calculated from ingredients on save)
  caloriesPerServing                                                         Int?
  proteinPerServing                                                          Float?
  fatPerServing                                                              Float?
  carbsPerServing                                                            Float?
  fiberPerServing                                                            Float?
  nutritionCompleteness                                                      Float?
  difficulty                                                                 Difficulty          @default(MEDIUM)
  status                                                                     RecipeStatus        @default(DRAFT)
  publishedAt                                                                DateTime?
  rating                                                                     Float               @default(0)
  ratingCount                                                                Int                 @default(0)
  viewCount                                                                  Int                 @default(0)
  cookCount                                                                  Int                 @default(0)
  isTrending                                                                 Boolean             @default(false)

  // Flow data as JSON
  flowNodes                                                                  Json?
  flowEdges                                                                  Json?

  // AI-assisted flow generation (prepared for future use)
  rawRecipeText String?  // Classic text recipe, sent to AI to generate flow

  // Import source (YouTube/TikTok/website URL for embeds)
  sourceUrl     String?  @db.VarChar(2048)

  // Content moderation
  moderationStatus                                                           ModerationStatus    @default(AUTO_APPROVED)
  moderationNote                                                             String?
  aiModerationScore                                                          Float?

  authorId                                                                   String
  createdAt                                                                  DateTime            @default(now())
  updatedAt                                                                  DateTime            @updatedAt

  //                                                                         Relations
  author                                                                     User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  categories                                                                 RecipeCategory[]
  recipeIngredients                                                          RecipeIngredient[]
  comments                                                                   Comment[]
  ratings                                                                    UserRating[]
  favorites                                                                  Favorite[]
  tags                                                                       RecipeTag[]
  mealPlanRecipes                                                            MealPlanRecipe[]
  shoppingItems                                                              ShoppingItem[]
  userViewHistory                                                            UserViewHistory[]
  cookHistory                                                                UserCookHistory[]
  pinnedFavorites                                                            PinnedFavorite[]
  cookImages                                                                 CookImage[]
  importRuns                                                                 ImportRun[]
  stepImages                                                                 RecipeStepImage[]
  embedding                                                                  RecipeEmbedding?
  plannedStreams                                                              PlannedStream[]

  @@index([authorId])
  @@index([difficulty])
  @@index([createdAt])
  @@index([rating])
  @@index([status])
  @@index([isTrending])
  @@index([moderationStatus])
}

model RecipeEmbedding {
  recipeId  String   @id
  embedding Float[]
  model     String   @db.VarChar(60)
  createdAt DateTime @default(now())

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model TwitchStream {
  id                String    @id @default(cuid())
  userId            String    @unique
  isLive            Boolean   @default(false)

  // Live state (from EventSub)
  twitchStreamId    String?
  startedAt         DateTime?
  endedAt           DateTime?
  title             String?
  viewerCount       Int?

  // EventSub tracking
  eventSubOnlineId  String?   @unique
  eventSubOfflineId String?   @unique
  eventSubSecret    String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isLive])
}

model PlannedStream {
  id                String    @id @default(cuid())
  userId            String
  recipeId          String
  plannedAt         DateTime?
  plannedTimezone   String?   @db.VarChar(60)
  twitchSegmentId   String?   @db.VarChar(120)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe            Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([recipeId])
}

// ============================================
// RECIPE STEP IMAGES
// ============================================

model RecipeStepImage {
  id        String    @id @default(cuid())
  recipeId  String
  stepId    String
  photoKey  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, stepId])
  @@index([recipeId])
  @@index([photoKey])
}

// ============================================
// RECIPE IMPORTER RUNS (audit + cost tracking)
// ============================================

enum ImportRunStatus {
  SUCCESS  // AI analyzed + recipe saved
  FALLBACK // AI failed/unavailable, used regex fallback parser
  FAILED   // Hard failure (scraping error, unrecoverable)
}

model ImportRun {
  id                                                                           String           @id @default(cuid())
  userId                                                                       String

  //                                                                           Source
  sourceUrl        String?         // null = pasted text (AI dialog in editor)
  sourceType                                                                   String           @default("url") // "url" | "text"
  markdownLength   Int?            // scraped content size in chars

  //                                                                           Result
  status                                                                       ImportRunStatus
  errorType        String?         // maps to ErrorType enum from importer
  errorMessage                                                                 String?
  recipeId         String?         // linked recipe if successfully saved

  // AI usage (matches OpenAI usage object fields)
  model             String?         // e.g. "gpt-4o-mini"
  inputTokens       Int?            // prompt_tokens
  cachedInputTokens Int?            // prompt_tokens_details.cached_tokens
  outputTokens      Int?            // completion_tokens
  // Cost: input $2.50/1M, cached $0.25/1M, output $15.00/1M
  estimatedCostUsd                                                             Float?

  // Raw OpenAI completion object for debugging & auditing
  rawApiResponse                                                               Json?

  createdAt                                                                    DateTime         @default(now())

  user                                                                         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe                                                                       Recipe?         @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId,                                                             createdAt])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// INGREDIENTS (Master List + Recipe-specific)
// ============================================

model Ingredient {
  id              String              @id @default(cuid())
  name            String
  slug            String              @unique
  pluralName      String?
  aliases         String[]            @default([])
  needsReview     Boolean             @default(false)
  createdAt       DateTime            @default(now())

  // Swiss Food DB reference
  swissFoodId              Int?    @unique

  // Nutrition per 100g (from Swiss Food Composition Database V 7.0)
  energyKj                 Float?
  energyKcal               Float?
  fat                      Float?
  saturatedFat             Float?
  monoUnsaturatedFat       Float?
  polyUnsaturatedFat       Float?
  linoleicAcid             Float?
  alphaLinolenicAcid       Float?
  epa                      Float?
  dha                      Float?
  cholesterol              Float?
  carbs                    Float?
  sugar                    Float?
  starch                   Float?
  fiber                    Float?
  protein                  Float?
  salt                     Float?
  alcohol                  Float?
  water                    Float?
  sodium                   Float?
  vitaminA_RE              Float?  @map("vitamin_a_re")
  vitaminA_RAE             Float?  @map("vitamin_a_rae")
  retinol                  Float?
  betaCaroteneActivity     Float?  @map("beta_carotene_activity")
  betaCarotene             Float?  @map("beta_carotene")
  vitaminB1                Float?  @map("vitamin_b1")
  vitaminB2                Float?  @map("vitamin_b2")
  vitaminB6                Float?  @map("vitamin_b6")
  vitaminB12               Float?  @map("vitamin_b12")
  niacin                   Float?
  folate                   Float?
  pantothenicAcid          Float?  @map("pantothenic_acid")
  vitaminC                 Float?  @map("vitamin_c")
  vitaminD                 Float?  @map("vitamin_d")
  vitaminE                 Float?  @map("vitamin_e")
  potassium                Float?
  chloride                 Float?
  calcium                  Float?
  magnesium                Float?
  phosphorus               Float?
  iron                     Float?
  iodine                   Float?
  zinc                     Float?
  selenium                 Float?

  // Relations
  categories      IngredientCategory[]
  ingredientUnits IngredientUnit[]
  recipes         RecipeIngredient[]
  shoppingItems   ShoppingItem[]

  @@index([name])
  @@index([aliases], type: Gin)
}

model IngredientCategory {
  id          String               @id @default(cuid())
  name        String
  slug        String               @unique
  sortOrder   Int                  @default(0)
  parentId    String?
  parent      IngredientCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    IngredientCategory[] @relation("CategoryTree")
  ingredients Ingredient[]

  @@index([parentId])
}

model Unit {
  id           String           @id @default(cuid())
  shortName    String           @unique
  longName     String           @unique
  gramsDefault Float?
  ingredients  IngredientUnit[]
}

model IngredientUnit {
  ingredientId String
  unitId       String
  grams        Float?

  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  unit         Unit       @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@id([ingredientId, unitId])
  @@index([ingredientId])
  @@index([unitId])
}

model RecipeIngredient {
  id                                                                  String      @id @default(cuid())
  recipeId                                                            String
  ingredientId                                                        String
  amount       String   // Recipe-specific: "400", "1/2", "2-3"
  unit         String   // Selected unit from ingredient.units
  notes        String?  // "finely chopped", "room temperature", etc.
  position                                                            Int         @default(0) // For ordering in list
  isOptional                                                          Boolean     @default(false)

  recipe                                                              Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient                                                          Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([recipeId,                                                 ingredientId])
  @@index([recipeId])
  @@index([ingredientId])
}

// ============================================
// CATEGORIES & TAGS
// ============================================

model Category {
  id                                                                            String            @id @default(cuid())
  name                                                                          String            @unique
  slug                                                                          String            @unique
  description                                                                   String?
  color                                                                         PaletteColor      @default(orange)
  icon          String?  // Lucide icon name (e.g. "utensils", "cake", "salad")
  coverImageKey String?  // S3 key for hero/cover image
  sortOrder                                                                     Int               @default(0)
  createdAt                                                                     DateTime          @default(now())

  recipes                                                                       RecipeCategory[]
}

model RecipeCategory {
  recipeId   String
  categoryId String
  position   Int       @default(0) // For ordering categories

  recipe     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([recipeId, categoryId])
  @@index([recipeId])
  @@index([categoryId])
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  slug      String       @unique
  recipes   RecipeTag[]
  createdAt DateTime     @default(now())
}

model RecipeTag {
  recipeId  String
  tagId     String
  createdAt DateTime  @default(now())

  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([recipeId, tagId])
}

model Comment {
  id               String            @id @default(cuid())
  content          String
  imageKey         String?
  recipeId         String
  authorId         String
  moderationStatus ModerationStatus  @default(AUTO_APPROVED)
  isHidden         Boolean           @default(false)
  moderationNote   String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  recipe           Recipe           @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  author           User             @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([authorId])
  @@index([moderationStatus])
}

// ============================================
// SOCIAL: RATINGS & FAVORITES
// ============================================

model UserRating {
  id                        String    @id @default(cuid())
  recipeId                  String
  userId                    String
  rating    Int      // 1-5
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  recipe                    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([recipeId,       userId])
  @@index([recipeId])
  @@index([userId])
}

model Favorite {
  id        String    @id @default(cuid())
  recipeId  String
  userId    String
  createdAt DateTime  @default(now())

  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([recipeId, userId])
  @@index([userId])
  @@index([recipeId, createdAt])
}

// ============================================
// SOCIAL: FOLLOW SYSTEM
// ============================================

model Follow {
  id          String    @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime  @default(now())

  follower    User     @relation("FollowedBy", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id                                                                        String            @id @default(cuid())
  userId                                                                    String
  type                                                                      NotificationType
  title                                                                     String
  message                                                                   String
  data      Json?            // Additional data: { recipeId, userId, etc. }
  read                                                                      Boolean           @default(false)
  createdAt                                                                 DateTime          @default(now())

  user                                                                      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId,                                                          read])
}

model PushSubscription {
  id                                                String    @id @default(cuid())
  userId                                            String
  endpoint                                          String    @unique
  keys                                              Json
  label     String?  // e.g. device or browser name
  createdAt                                         DateTime  @default(now())
  updatedAt                                         DateTime  @updatedAt

  user                                              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// MEAL PLANNING
// ============================================

model MealPlan {
  id            String            @id @default(cuid())
  userId        String
  name          String?
  startDate     DateTime
  endDate       DateTime
  meals         MealPlanRecipe[]
  shoppingLists ShoppingList[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, startDate])
}

model MealPlanRecipe {
  id         String      @id @default(cuid())
  mealPlanId String
  recipeId   String
  date       DateTime
  mealType   MealType
  servings   Int         @default(4)
  status     MealStatus  @default(PLANNED)
  notes      String?

  mealPlan   MealPlan   @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([mealPlanId])
  @@index([recipeId])
}

// ============================================
// SHOPPING LISTS
// ============================================

model ShoppingList {
  id         String          @id @default(cuid())
  userId     String
  name       String?
  mealPlanId String?
  items      ShoppingItem[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealPlan   MealPlan?      @relation(fields: [mealPlanId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model ShoppingItem {
  id                                                              String            @id @default(cuid())
  shoppingListId                                                  String
  recipeId       String?          // Original recipe (optional)
  ingredientId   String?          // Master ingredient (optional)
  name           String           // Display name (fallback)
  amount                                                          String?
  unit                                                            String?
  checked                                                         Boolean           @default(false)
  position                                                        Int               @default(0)

  shoppingList                                                    ShoppingList     @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  recipe                                                          Recipe?          @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  ingredient                                                      Ingredient?      @relation(fields: [ingredientId], references: [id], onDelete: SetNull)

  @@index([shoppingListId])
}

// ============================================
// ACTIVITY & VIEW HISTORY
// ============================================

model ActivityLog {
  id         String        @id @default(cuid())
  userId     String
  type       ActivityType
  targetId   String?
  targetType String?
  metadata   Json?
  createdAt  DateTime      @default(now())

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model UserViewHistory {
  id       String    @id @default(cuid())
  userId   String
  recipeId String
  viewedAt DateTime  @default(now())
  pinned   Boolean   @default(false)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([userId])
  @@index([recipeId])
  @@index([userId, viewedAt])
  @@index([recipeId, viewedAt])
}

model UserCookHistory {
  id                                         String    @id @default(cuid())
  userId                                     String
  recipeId                                   String
  cookedAt                                   DateTime  @default(now())
  servings                                   Int?
  notes                                      String?
  imageKey  String?  // S3 key for the image

  user                                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe                                     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([recipeId])
  @@index([userId,                           cookedAt])
  @@index([recipeId,                         cookedAt])
}

// ============================================
// COOK IMAGES (User-submitted photos)
// ============================================

model CookImage {
  id               String            @id @default(cuid())
  recipeId         String
  userId           String
  imageKey         String
  blurhash         String?
  caption          String?
  moderationStatus ModerationStatus  @default(AUTO_APPROVED)
  isHidden         Boolean           @default(false)
  createdAt        DateTime          @default(now())

  recipe           Recipe           @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([userId])
  @@index([createdAt])
  @@index([moderationStatus])
}

// ============================================
// PINNED FAVORITES (KUC-5)
// ============================================

model PinnedFavorite {
  id                                       String    @id @default(cuid())
  userId                                   String
  recipeId                                 String
  position  Int      // 0, 1, or 2 (max 3)
  createdAt                                DateTime  @default(now())

  user                                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe                                   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId,                        position])
  @@unique([userId,                        recipeId])
  @@index([userId])
}

// ============================================
// CONTENT MODERATION
// ============================================

model ModerationQueue {
  id                                                                                 String            @id @default(cuid())
  contentType    String           // "recipe" | "comment" | "profile" | "cook_image"
  contentId      String           // FK to the relevant record
  authorId       String           // User who submitted the content
  author                                                                             User             @relation("ModerationQueueAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  // AI moderation results
  aiScore        Float            // 0.0–1.0 highest category score
  aiFlags        Json             // { hate: 0.01, sexual: 0.82, ... }
  aiRawResponse  Json             // full OpenAI moderation API response

  // Human review
  status                                                                             ModerationStatus  @default(PENDING)
  reviewedBy     String?          // moderator/admin userId
  reviewer                                                                           User?            @relation("ModerationQueueReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt                                                                         DateTime?
  reviewNote     String?          // internal note from reviewer

  // Content snapshot (so mod can see what was submitted even if edited)
  contentSnapshot Json            // { title?, description?, imageUrl?, text? }

  createdAt                                                                          DateTime          @default(now())
  updatedAt                                                                          DateTime          @updatedAt

  @@index([contentType,                                                              contentId])
  @@index([status,                                                                   createdAt])
  @@index([authorId])
}

model ModerationLog {
  id                                                                                                             String    @id @default(cuid())
  actorId      String   // who took the action (admin/mod)
  actor                                                                                                          User     @relation("ModerationLogActor", fields: [actorId], references: [id], onDelete: Cascade)
  action       String   // "approve" | "reject" | "ban_user" | "unban_user" | "hide_content" | "restore_content"
  contentType  String?  // "recipe" | "comment" | "user" | etc.
  contentId    String?  // target content ID
  reason       String?  // human-provided reason
  metadata     Json?    // extra context
  createdAt                                                                                                      DateTime  @default(now())

  @@index([actorId])
  @@index([contentId])
}

model Report {
  id                                                                            String    @id @default(cuid())
  reporterId                                                                    String
  reporter                                                                      User     @relation("ReportSubmitter", fields: [reporterId], references: [id], onDelete: Cascade)
  contentType String   // "recipe" | "comment" | "user"
  contentId                                                                     String
  reason      String   // "spam" | "nsfw" | "hate" | "misinformation" | "other"
  description String?  // optional free text from reporter
  resolved                                                                      Boolean   @default(false)
  resolvedBy                                                                    String?
  createdAt                                                                     DateTime  @default(now())

  @@unique([reporterId, contentType, contentId])
  @@index([contentType,                                                         contentId])
  @@index([resolved])
}

// ============================================
// SITE SETTINGS
// ============================================

model SiteSettings {
  id        String    @id @default(cuid())
  key       String    @unique
  value     Json?
  updatedAt DateTime  @updatedAt
  updatedBy String?
}

// ============================================
// JOB RUNS (BullMQ History)
// ============================================

model JobRun {
  id                                                String     @id @default(cuid())
  queueName                                         String
  jobName                                           String
  jobId        String?   // BullMQ job ID
  status                                            JobStatus  @default(PENDING)
  payload      Json?     // Job input data
  result       Json?     // Job output/result
  errorMessage String?   // Error message if failed
  attempts                                          Int        @default(0)
  startedAt                                         DateTime?
  completedAt                                       DateTime?
  createdAt                                         DateTime   @default(now())

  @@index([queueName,                               createdAt])
  @@index([status,                                  createdAt])
  @@index([jobId])
}

// ============================================
// TROPHIES / ACHIEVEMENTS
// ============================================

model Trophy {
  id                                                             String        @id // slug: "finished-tutorial" or "recipe-creator:bronze"
  groupSlug                                                      String
  tier                                                           TrophyTier    @default(NONE)
  category     String       // "ONBOARDING", "COOKING", "SOCIAL"
  name                                                           String
  description                                                    String
  icon         String       // Lucide icon name
  points                                                         Int           @default(0)
  sortOrder                                                      Int           @default(0)
  userTrophies                                                   UserTrophy[]
  createdAt                                                      DateTime      @default(now())

  @@unique([groupSlug,                                           tier])
}

model UserTrophy {
  id       String    @id @default(cuid())
  userId   String
  trophyId String
  earnedAt DateTime  @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trophy   Trophy   @relation(fields: [trophyId], references: [id])

  @@unique([userId, trophyId])
  @@index([userId])
}
