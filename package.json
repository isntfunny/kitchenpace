{
    "name": "kitchenpace",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,css,md,yml,yaml}": [
            "prettier --write"
        ]
    },
    "bin": {
        "kitchen": "./cli/index.ts"
    },
    "scripts": {
        "panda": "panda codegen --config ./panda.config.ts",
        "predev": "npm run panda",
        "prebuild": "npm run panda && npx prisma generate",
        "postinstall": "npm run panda",
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test:e2e": "playwright test",
        "test:load": "./k6/run-load-test.sh",
        "test:load:dashboard": "./k6/run-dashboard.sh",
        "test:load:light": "./k6/run-load-test.sh light",
        "test:load:medium": "./k6/run-load-test.sh medium",
        "test:load:heavy": "./k6/run-load-test.sh heavy",
        "test:load:granular": "./k6/run-load-test.sh granular",
        "test:load:smoke": "cd k6 && k6 run smoke-test.js",
        "test:load:prod": "./k6/run-load-test.sh prod https://beta.xn--kchentakt-q9a.de/",
        "prepare": "husky",
        "db:generate": "prisma generate",
        "db:push": "prisma db push",
        "db:migrate": "prisma migrate dev",
        "db:seed": "tsx src/lib/seed.ts",
        "db:seed-basics": "tsx src/lib/seed-basics.ts",
        "db:reset": "prisma migrate reset --force && npx prisma db push --accept-data-loss && npm run db:seed-basics",
        "db:fresh": "npm run db:generate && prisma migrate reset --force && npx prisma db push --accept-data-loss && npm run db:seed",
        "build:dev-seed": "DEBUG=1 npm run build && npm run db:fresh",
        "worker": "tsx worker/entrypoint.ts",
        "cli": "tsx cli/index.ts",
        "emails:push": "node email-templates/push.mjs",
        "emails:push:dry": "node email-templates/push.mjs --dry-run",
        "emails:validate": "node email-templates/validate.mjs"
    },
    "prisma": {
        "prisma": {
            "seed": "tsx src/lib/seed.ts"
        }
    },
    "dependencies": {
        "@auth/prisma-adapter": "^2.11.1",
        "@aws-sdk/client-s3": "^3.1003.0",
        "@aws-sdk/lib-storage": "^3.1003.0",
        "@floating-ui/react": "^0.27.19",
        "@inquirer/prompts": "^8.3.0",
        "@marsidev/react-turnstile": "^1.4.2",
        "@mediapipe/tasks-vision": "^0.10.32",
        "@onboardjs/core": "^1.0.0-rc.3",
        "@onboardjs/react": "^1.0.0-rc.3",
        "@openpanel/nextjs": "^1.3.0",
        "@opensearch-project/opensearch": "^3.5.1",
        "@pandacss/dev": "^1.8.2",
        "@prisma/adapter-pg": "^7.4.2",
        "@prisma/client": "^7.4.2",
        "@radix-ui/colors": "^3.0.0",
        "@sentry/nextjs": "^10.42.0",
        "@styled-system/css": "^5.1.5",
        "@tanstack/react-table": "^8.21.3",
        "@xyflow/react": "^12.10.1",
        "bcrypt": "^6.0.0",
        "bullmq": "^5.70.4",
        "chalk": "^5.6.2",
        "commander": "^14.0.3",
        "dagre": "^0.8.5",
        "dotenv": "^17.3.1",
        "file-saver": "^2.0.5",
        "ioredis": "^5.10.0",
        "jose": "^6.2.0",
        "jspdf": "^4.2.0",
        "lodash": "^4.17.23",
        "lucide-react": "^0.577.0",
        "motion": "^12.35.0",
        "next": "16.1.6",
        "next-auth": "^4.24.13",
        "next-nprogress-bar": "^2.4.7",
        "openai": "^6.27.0",
        "ora": "^9.3.0",
        "pg": "^8.20.0",
        "postcss": "^8.5.8",
        "prisma": "^7.4.2",
        "radix-ui": "^1.4.3",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-qr-code": "^2.0.18",
        "sharp": "^0.34.5",
        "styled-system": "^5.1.5",
        "swr": "^2.4.1",
        "tsx": "^4.21.0",
        "winston": "^3.19.0",
        "yet-another-react-lightbox": "^3.29.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@types/bcrypt": "^6.0.0",
        "@types/dagre": "^0.7.54",
        "@types/file-saver": "^2.0.7",
        "@types/lodash": "^4.17.24",
        "@types/node": "^24",
        "@types/pg": "^8.18.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@uiw/react-json-view": "^2.0.0-alpha.41",
        "eslint": "^9",
        "eslint-config-next": "^16.1.6",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-unused-imports": "^4.4.1",
        "html-to-image": "^1.11.13",
        "husky": "^9.1.7",
        "lint-staged": "^16.3.2",
        "lucide": "^0.577.0",
        "mjml-parser-xml": "^4.18.0",
        "node-html-parser": "^7.1.0",
        "prettier": "^3.8.1",
        "typescript": "^5",
        "web-push": "^3.6.7"
    }
}
