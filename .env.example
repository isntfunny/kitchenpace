# Database (Prisma 7)
DATABASE_URL="postgresql://user:password@localhost:5432/kitchenpace"

# Optional: Shadow database for migrations (needed for cloud-hosted databases like Neon, Supabase)
# SHADOW_DATABASE_URL="postgresql://user:password@localhost:5432/kitchenpace_shadow"

# OpenSearch
OPENSEARCH_URL="http://localhost:9200"
OPENSEARCH_INDEX="recipes"
OPENSEARCH_INGREDIENTS_INDEX="ingredients"

# Trigger.dev (self-hosted)
TRIGGER_API_URL="https://task-trigger.isntfunny.de"
TRIGGER_ACCESS_TOKEN=""

# Redis
REDIS_PASSWORD="kitchenpace_secret"

# S3/MinIO Configuration
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="kitchenpace-uploads"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_REGION="us-east-1"

# App URL (for generating links in emails)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Flipt Feature Flags (self-hosted)
FLIPT_URL="https://feature.isntfunny.de"

# Local fallback flags (used until Flipt is configured)
# FEATURE_GESTURE_NAVIGATION="0"
# FEATURE_HELLO_WORLD_BANNER="0"

# Notifuse transactional email configuration
NOTIFUSE_API_KEY=""
NOTIFUSE_WORKSPACE_ID=""
NOTIFUSE_BASE_URI="https://api.notifuse.com/v2/"
NOTIFUSE_EMAIL_CHANNEL="sendgrid"
NOTIFUSE_NOTIFICATION_PASSWORD_RESET="password-reset"
NOTIFUSE_TEMPLATE_PASSWORD_RESET="default"
NOTIFUSE_NOTIFICATION_ACTIVATION="account-activation"
NOTIFUSE_TEMPLATE_ACTIVATION="default"
NOTIFUSE_NOTIFICATION_WELCOME="welcome"
NOTIFUSE_TEMPLATE_WELCOME="default"

# Seq Logging (optional)
SEQ_URL="https://logs.isntfunny.de"
SEQ_API_KEY="your-seq-api-key"

# Scrapler Service (recipe import)
SCRAPLER_URL=http://localhost:34215

# OpenAI (for recipe import AI analysis)
OPENAI_API_KEY="sk-..."

# Discord OAuth (optional - button only shown when NEXT_PUBLIC_DISCORD_ENABLED=1)
# DISCORD_CLIENT_ID=""
# DISCORD_CLIENT_SECRET=""
# NEXT_PUBLIC_DISCORD_ENABLED="1"

# Cloudflare Turnstile (registration captcha)
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=""
CLOUDFLARE_TURNSTILE_SECRET_KEY=""

# Content Moderation (OpenAI Moderation API — uses OPENAI_API_KEY above)
# Override default thresholds (0.40 review, 0.85 reject)
# MODERATION_TEXT_THRESHOLD_REVIEW="0.40"
# MODERATION_TEXT_THRESHOLD_REJECT="0.85"

# OpenPanel Analytics
OPENPANEL_CLIENT_ID="your-client-id"
OPENPANEL_CLIENT_SECRET="your-client-secret"
OPENPANEL_API_URL="https://your-api-url.com"

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================

# Local backup directory (mounted persistent volume)
BACKUP_DIR="/app/backups"

# Retention (MinIO)
BACKUP_RETENTION_HOURLY=7
BACKUP_RETENTION_DAILY=30

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@kuechentakt.de
